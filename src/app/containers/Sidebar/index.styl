.navbar {
    position: relative;
    height: 100%;
    background:
        linear-gradient(180deg, rgba(10, 23, 40, .96), rgba(5, 11, 21, .98));
}

.icon {
    display: inline-block;
    vertical-align: middle;
    width: 32px;
    height: 32px;

    &.icon-xyz {
        background: url("./images/xyz.svg") no-repeat 0 0;
    }
    &.icon-gear {
        background: url("./images/gear.svg") no-repeat 0 0;
    }
}

.nav {
    padding-left: 0;
    margin-bottom: 0;
    list-style: none;
    padding-top: 8px;

    > li {
        position: relative;
        display: block;

        > a {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 76px;
            margin: 0 6px 6px;
            background-color: transparent;
            border: 1px solid transparent;
            border-radius: 6px;
            color: #8fa4c0;
            text-decoration: none;
            white-space: nowrap;
            padding: 10px 0 8px;
            transition: background .16s ease, border-color .16s ease, color .16s ease;

            > .icon.icon-invert {
                filter: invert(66%);
            }
        }
        > a:focus,
        > a:hover {
            color: #f8fbff;
            background-color: rgba(47, 129, 247, .09);
            border-color: rgba(88, 166, 255, .26);

            > .icon.icon-invert {
                filter: invert(100%);
            }
        }
    }
    > li.active {
        > a,
        > a:focus,
        > a:hover {
            color: #58a6ff;
            background-color: rgba(47, 129, 247, .14);
            border-color: rgba(88, 166, 255, .52);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06), 0 0 18px rgba(47, 129, 247, .16);

            > .icon.icon-invert {
                filter: invert(100%);
            }
        }
    }
}

.label {
    display: block;
    margin-top: 8px;
    color: inherit;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: .04em;
    line-height: 12px;
    text-transform: uppercase;
}
