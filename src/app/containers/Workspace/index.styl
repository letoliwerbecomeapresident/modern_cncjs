@import "../variables";

.workspace {
    .dropzone-overlay {
        position: fixed;
        top: $navbar-height;
        bottom: 0;
        left: $sidebar-width;
        right: 0;
        z-index: 100;
        background-color: rgba(8, 19, 34, .82);
        border: 2px dashed #2f81f7;
        text-align: center;
        pointer-events: none;
        backdrop-filter: blur(8px);

        &.hidden {
            display: none;
        }

        .text-block {
            position: absolute;
            top: 25%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #dbe8ff;
            font-size: 26px;
            font-weight: 700;
        }
    }
    .dropzone {
        height: 100%;
    }

    .workspace-table {
        display: block;
        width: 100%;
        height: 'calc(100vh - %s)' % ($navbar-height);
        overflow: hidden;
    }
    .workspace-table-row {
        display: block;
        width: 100%;
        height: 100%;
    }

    .primary-container,
    .secondary-container,
    .primary-toggler,
    .secondary-toggler {
        position: fixed;
        top: $navbar-height;
        bottom: 0;
        z-index: 10;
        background-color: transparent !important;
        border: none !important;
    }

    .primary-container {
        left: $sidebar-width;
        width: 350px;
        max-width: 350px;
        min-width: 350px;
        padding: 8px;
        overflow-y: auto;
    }

    .secondary-container {
        right: 0;
        width: 420px;
        max-width: 420px;
        min-width: 420px;
        padding: 8px;
        overflow-y: auto;
    }

    .primary-toggler {
        left: $sidebar-width;
        width: $toggler-width;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(15, 35, 59, .45) !important;
        border-right: 1px solid rgba(84, 119, 167, .2) !important;
    }

    .secondary-toggler {
        right: 0;
        width: $toggler-width;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(15, 35, 59, .45) !important;
        border-left: 1px solid rgba(84, 119, 167, .2) !important;
    }

    .default-container {
        min-width: 360px;

        &.fixed {
            position: fixed;
            left: 350px;
            right: 420px;
            top: ($navbar-height + 1);
            bottom: 0;
            padding: 8px;
            background-color: transparent;
            overflow-y: auto;
        }
    }
}
