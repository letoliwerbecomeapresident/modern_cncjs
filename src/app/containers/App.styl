@import "variables";

.sidebar {
    background-color: $sidebar-background-color;
    position: fixed;
    top: $navbar-height;
    left: 0;
    bottom: 0;
    width: $sidebar-width;
    z-index: 1000;
    border-right: 1px solid rgba(84, 119, 167, .22);
    box-shadow: inset -1px 0 0 rgba(255, 255, 255, .03);
}

.main {
    position: absolute;
    top: $navbar-height;
    left: $sidebar-width;
    right: 0;
    bottom: 0;
    background-color: $content-background-color;
    min-width: $content-min-width;
    color: #dbe8ff;
    background-image:
        radial-gradient(circle at 50% -20%, rgba(23, 101, 220, .18), rgba(7, 17, 31, 0) 42%),
        linear-gradient(180deg, #091526 0%, #07111f 42%, #050b15 100%);
}

.content {
    position: relative;
    background-color: $content-background-color;
    min-height: 'calc(100vh - %s)' % ($navbar-height);
}
