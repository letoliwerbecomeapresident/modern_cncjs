.widget-content {
    position: relative;

    &.hidden {
        display: none;
    }

    &.fullscreen {
        .terminal-container {
            height: 100%;
        }
    }
}

.no-serial-connection {
    padding: 10px;
    color: #8fa4c0;
}

.terminal-container {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    background: #030812;
    border: 1px solid rgba(82, 112, 154, .22);
    border-radius: 5px;
    box-shadow: inset 0 10px 24px rgba(0, 0, 0, .28);
    color: #fff;
    font-family: Consolas, Menlo, Monaco, 'Lucida Console', 'Liberation Mono', 'DejaVu Sans Mono', 'Bitstream Vera Sans Mono', 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.4;
    overflow: hidden;
}

.terminal-output {
    flex: 1 1 auto;
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    padding: 4px 6px 0;
    white-space: pre-wrap;
    word-break: break-all;
}

.terminal-line {
    min-height: 1.4em;
}

.terminal-input-row {
    display: flex;
    align-items: baseline;
    padding: 2px 6px 4px;
    border-top: 1px solid rgba(82, 112, 154, .12);
}

.terminal-prompt {
    color: #fff;
    margin-right: 2px;
    user-select: none;
}

.terminal-input {
    flex: 1 1 auto;
    background: transparent;
    border: 0;
    outline: 0;
    color: #fff;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    padding: 0;
    width: 100%;

    &.cursor-blink {
        caret-color: currentColor;
    }
}

.fg-black { color: #000; }
.fg-red { color: #cc0000; }
.fg-green { color: #4e9a06; }
.fg-yellow { color: #c4a000; }
.fg-blue { color: #3465a4; }
.fg-magenta { color: #75507b; }
.fg-cyan { color: #06989a; }
.fg-white { color: #fff; }
.fg-gray { color: #888a85; }
.fg-red-bright { color: #ef2929; }
.fg-green-bright { color: #8ae234; }
.fg-yellow-bright { color: #fce94f; }
.fg-blue-bright { color: #729fcf; }
.fg-magenta-bright { color: #ad7fa8; }
.fg-cyan-bright { color: #34e2e2; }
.fg-white-bright { color: #eeeeec; }

.bold {
    font-weight: 700;
}

.icon {
    display: inline-block;
    width: 14px;
    height: 14px;
    vertical-align: middle;
    margin: 0 2px 2px 2px;

    &.select-all {
        background: url("./images/select-all.svg") no-repeat 0 0;
    }
}
