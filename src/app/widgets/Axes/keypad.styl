.keypad {
    button.btn-keypad {
        font-size: 16px;
        padding: 0;
        width: 100%;
        line-height: 34px;
        text-align: center;
        vertical-align: middle;
        background: linear-gradient(180deg, #142944, #0c1b30) !important;
        border-color: rgba(82, 112, 154, .34) !important;
        color: #dbe8ff !important;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06), 0 8px 16px rgba(0, 0, 0, .18);

        &:active,
        &.active {
            box-shadow: inset 0 2px 8px rgba(0, 0, 0, .35);
            transform: translate(1px, 1px);
        }

        :global {
            i.fa,
            span.fa {
                color: #dbe8ff;
            }
        }

        &.highlight {
            background: linear-gradient(180deg, #1c3d66, #102743) !important;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, .08), 0 0 0 1px rgba(88, 166, 255, .24);
            border-color: rgba(88, 166, 255, .45) !important;

            &:hover,
            &.hover {
                background: linear-gradient(180deg, #245184, #14345a) !important;
            }

            &:active,
            &.active {
                box-shadow: 0 0 2px rgba(0, 0, 0, .2);
                transform: translate(1px, 1px);
            }
        }
    }
}
