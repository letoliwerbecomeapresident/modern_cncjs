.display-panel {
    color: #dbe8ff;

    :global {
        table {
            margin-bottom: 10px;
        }

        thead > tr > th {
            color: #8fa4c0;
            background: rgba(5, 12, 23, .28);
            border-color: rgba(82, 112, 154, .22);
            font-size: 10px;
            font-weight: 800;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        tbody > tr > td {
            border-color: rgba(82, 112, 154, .18);
        }
    }

    .coordinate {
        position: relative;
        padding: 5px 0;
        text-align: center;
        width: 1%;

        .axis {
            font-weight: 900;
            font-size: 24px;
            text-shadow: 0 0 12px rgba(88, 166, 255, .32);
        }
    }

    .machine-position,
    .work-position {
        position: relative;
        white-space: nowrap;
        padding: 0;
        width: 48%;
        color: #f8fbff;
        font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    }

    .action {
        width: 1%;
        padding: 0;
        text-align: center;

        button.action-dropdown {
            min-width: auto;
            border-radius: 5px;
            background: rgba(15, 35, 60, .74);
            border: 1px solid rgba(82, 112, 154, .3);

            > * {
                color: #8fa4c0;
            }

            &:disabled:hover {
                background-color: inherit;
                > * {
                    color: #666;
                }
            }
            &:hover {
                background-color: rgba(47, 129, 247, .16);
                > * {
                    color: #f8fbff;
                }
            }
        }
    }
}
