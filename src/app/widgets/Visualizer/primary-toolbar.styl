.primary-toolbar {
    color: #dbe8ff;

    .controller-type {
        display: inline-block;
        font-size: 14px;
        font-weight: bold;
        margin-right: 10px;
        padding: 4px 0;
    }
    .controller-state {
        display: none;
        color: #dbe8ff;
        background-color: rgba(15, 35, 60, .74);
        border: 1px solid rgba(82, 112, 154, .32);
        border-radius: 3px;
        min-width: 50px;
        text-align: center;
        padding: 4px 12px;
        font-size: 12px;
        line-height: 18px;

        &.controller-state-default {
            display: inline-block;
            color: #21d982;
            background-color: rgba(33, 217, 130, .12);
            border: 1px solid rgba(33, 217, 130, .32);
        }
        &.controller-state-primary {
            display: inline-block;
            color: #fff;
            background-color: #1269dc;
            border-color: rgba(88, 166, 255, .42);
        }
        &.controller-state-success {
            display: inline-block;
            color: #fff;
            background-color: #06945c;
            border-color: rgba(42, 226, 133, .42);
        }
        &.controller-state-info {
            display: inline-block;
            color: #fff;
            background-color: #0e7490;
            border-color: rgba(103, 232, 249, .42);
        }
        &.controller-state-warning {
            display: inline-block;
            color: #fff;
            background-color: #c75a04;
            border-color: rgba(251, 146, 60, .5);
        }
        &.controller-state-danger {
            display: inline-block;
            color: #fff;
            background-color: #b91c1c;
            border-color: rgba(248, 113, 113, .5);
        }
    }
}
