.workflow-control {
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;

    :global {
        .btn-group {
            background-color: rgba(5, 12, 23, .74);
            border-radius: 5px;
            box-shadow: 0 10px 24px rgba(0, 0, 0, .24);
        }
    }
}

.icon {
    display: inline-block;
    width: 14px;
    height: 14px;
    vertical-align: middle;
    margin-bottom: 4px; // dropdown menu item

    &.icon-perimeter-tracing-square {
        background: url("./images/perimeter-tracing-square.svg") no-repeat 0 0;
    }
    &.icon-perimeter-tracing-circle {
        background: url("./images/perimeter-tracing-circle.svg") no-repeat 0 0;
    }
}
