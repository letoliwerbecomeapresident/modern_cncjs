@import './theme';

.widget {
    background:
        linear-gradient(180deg, rgba(15, 31, 53, .96) 0%, rgba(10, 21, 38, .96) 100%);
    border: 1px solid rgba(72, 105, 151, .28);
    border-radius: 6px;
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, .06),
        0 16px 32px rgba(0, 0, 0, .22);
    color: #dbe8ff;
    margin-bottom: 8px;
    overflow: hidden;

    &.widget-borderless {
        .widget-header,
        .widget-content,
        .widget-footer {
            border: 0;
        }
        .widget-header + .widget-content,
        .widget-header + .widget-footer,
        .widget-content + .widget-footer {
            border-top: 1px solid rgba(72, 105, 151, .28);
        }
    }

    &.widget-fullscreen {
        position: fixed;
        top: 50px; // navbar
        left: 60px; // sidebar
        right: 0;
        bottom: 0;
        margin: 0;
        z-index: 1000;

        .widget-sortable {
            display: none;
        }
    }
    &.widget-fullscreen {
        .widget-content {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
        }
        .widget-header + .widget-content {
            position: absolute;
            top: 34px; // .widget-header height
            bottom: 0;
            left: 0;
            right: 0;
        }
    }

    .widget-header {
        clearfix();
        background:
            linear-gradient(180deg, rgba(19, 39, 66, .96), rgba(12, 26, 46, .96));
        border: 0;
        border-bottom: 1px solid rgba(72, 105, 151, .26);
        position: relative;
        color: #f8fbff;
    }
    .widget-header-fixed {
        cursor: default;
    }

    .widget-sortable {
        display: inline-block;
        cursor: move;

        > a {
            cursor: move;
        }
    }

    .widget-title {
        color: #f8fbff;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .03em;
        line-height: 32px;
        display: inline-block;
        vertical-align: middle;
        margin-top: 0;
        margin-bottom: 0;
        padding: 0 10px;

        // Truncate string with ellipsis
        text-overflow: ellipsis;
        overflow: hidden;
        white-space: nowrap;
        width: 100%;
        max-width: 100%;
    }

    .widget-content,
    .widget-footer {
        background-color: transparent;
        border: 0;
        border-top: none;
        color: #dbe8ff;
    }

    .widget-button {
        text-decoration: none;
        font-size: 14px;
        text-align: center;
        display: inline-block;
        line-height: 32px;
        padding: 0;
        margin: 0;
    }

    .widget-controls {
        position: absolute;
        top: 0;
        right: 0;
        cursor: auto;
        width: auto;

        .widget-button {
            min-width: 30px;
            height: 32px;
            float: left;
            position: relative;
            font-size: 14px;
            font-family: Arial, Helvetica, sans-serif;
            border-left: 1px solid rgba(72, 105, 151, .22);
            color: #8fa4c0;
            margin: 0;
            text-align: center;

            &.disabled {
                color: #bbb;
                cursor: not-allowed;
            }

            &.disabled:hover {
                background-color: inherit;
            }
            &:hover {
                background-color: rgba(47, 129, 247, .12);
                color: #f8fbff;
            }

            &.inverted {
                color: #fff;
                background-color: #132944;
            }
            &.inverted:hover {
                background-color: #17406f;
            }
            &.inverted.disabled {
                opacity: .4;
            }

            &:first-child {
                padding-left: 0;
            }
        }
    }
}
