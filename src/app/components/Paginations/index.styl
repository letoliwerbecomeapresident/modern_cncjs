.table-pagination {
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.records {
    color: #666;
    white-space: nowrap;
}

.page-length {
    height: 30px;
    padding: 0 4px;
    border: 1px solid #ccc;
    border-radius: 3px;
    background: #fff;
}

.page-info {
    color: #666;
    white-space: nowrap;
}
